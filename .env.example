# Google Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# --- Email: lead magnet + daily sequence (Resend) ---
# 1) Create an account at https://resend.com and add + verify your sending domain
# 2) Create an API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# The "from" address, on your verified domain
RESEND_FROM=Damian <damian@tudominio.com>
# Audience that stores subscribers: https://resend.com/audiences
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Public URL of the site, used to build unsubscribe links inside emails (no trailing slash)
PUBLIC_SITE_URL=https://tudominio.com

# Any long random string — signs unsubscribe links so they can't be forged
UNSUBSCRIBE_SECRET=change_me_to_a_long_random_string
# Any long random string — protects the daily cron endpoint.
# On Vercel, set this env var and Cron will send it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=change_me_to_a_long_random_string
